# ─── CH16Hyla Environment Configuration ────────────────────────────────────────

# ── New CH16 Database (write target) ────────────────────────────────────────────
MONGO_URI=mongodb://user:password@host:port/admin
CH16_DB_NAME=CH16db

# ── Source Databases (READ-ONLY) ────────────────────────────────────────────────
HYLATRIAL_DB=HylaTrial
HYLA_ANALYTICS2_DB=HylaAnalytics2

# ── GreenHyla API ───────────────────────────────────────────────────────────────
GREENHYLA_API_URL=https://app.greenhyla.com/auth/api/v1/external
GREENHYLA_API_KEY=your_api_key_here

# ── Cron Job Interval ───────────────────────────────────────────────────────────
CRON_INTERVAL_MINUTES=10

# ── JWT Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_32_chars_min
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Server Ports ────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
SCHEDULER_PORT=5001

# ── CORS (comma-separated, no spaces) ───────────────────────────────────────────
CORS_ORIGINS=https://ch16.greenhyla.com
